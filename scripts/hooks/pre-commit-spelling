#!/usr/bin/env bash
#
# Pre-commit hook for spell checking with cspell.
#
# Uses British English (en-GB) as configured in cspell.json.
# Only checks staged files to avoid noise from existing content.

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# Get staged markdown files in content/
STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^content/.*\.md$' || true)

if [[ -z "$STAGED_MD_FILES" ]]; then
    exit 0
fi

# Check if cspell is available
if ! command -v cspell &> /dev/null; then
    echo -e "${YELLOW}Warning: cspell not found. Skipping spell check.${NC}"
    echo "Run 'nix develop' to get the required tools."
    exit 0
fi

echo -e "${YELLOW}Checking spelling (British English)...${NC}"
echo ""

ERRORS=0
ALL_UNKNOWN=""

for file in $STAGED_MD_FILES; do
    if [[ ! -f "$file" ]]; then
        continue
    fi

    # Run cspell and capture output
    OUTPUT=$(cspell --no-progress --no-summary "$file" 2>&1 || true)

    if [[ -n "$OUTPUT" ]]; then
        echo -e "  ${RED}✗${NC} $file"
        # Extract just the unknown words
        UNKNOWN_WORDS=$(echo "$OUTPUT" | grep -oP "Unknown word \(\K[^)]+(?=\))" | sort -u || true)
        if [[ -n "$UNKNOWN_WORDS" ]]; then
            echo -e "    ${CYAN}Unknown words:${NC} $(echo $UNKNOWN_WORDS | tr '\n' ' ')"
            ALL_UNKNOWN="${ALL_UNKNOWN}${UNKNOWN_WORDS}\n"
        fi
        ERRORS=$((ERRORS + 1))
    else
        echo -e "  ${GREEN}✓${NC} $file"
    fi
done

echo ""

if [[ $ERRORS -gt 0 ]]; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}COMMIT REJECTED: $ERRORS file(s) have spelling errors${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "To fix spelling errors:"
    echo ""
    echo "  1. Correct the spelling in the file"
    echo "  2. Or add valid words to .cspell/project-words.txt"
    echo "  3. Or add to 'words' array in cspell.json"
    echo ""

    # Show unique unknown words
    UNIQUE_WORDS=$(echo -e "$ALL_UNKNOWN" | sort -u | grep -v '^$' || true)
    if [[ -n "$UNIQUE_WORDS" ]]; then
        echo -e "${CYAN}All unknown words:${NC}"
        echo "$UNIQUE_WORDS" | while read -r word; do
            echo "  - $word"
        done
        echo ""
        echo "To add all to project dictionary:"
        echo "  echo '$UNIQUE_WORDS' >> .cspell/project-words.txt"
    fi
    echo ""
    echo "To bypass (not recommended): git commit --no-verify"
    exit 1
fi

echo -e "${GREEN}All content files pass spell check.${NC}"
exit 0
