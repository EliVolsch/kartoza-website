#!/usr/bin/env bash
#
# Main pre-commit hook that runs all checks.
#
# Checks run:
# 1. Reviewer verification (content pages must have current reviewer/date)
# 2. Markdown linting and formatting (with autofix)
# 3. Spell checking (British English)
#
# Skip all checks with: git commit --no-verify (not recommended)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

echo -e "${BOLD}Running pre-commit checks...${NC}"
echo ""

FAILED=0

#
# Check 1: Reviewer verification
#
run_reviewer_check() {
    local GIT_USER=$(git config user.name)
    local TODAY=$(date +%Y-%m-%d)

    # Get staged content markdown files (excluding _index.md)
    local STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^content/.*\.md$' | grep -v '_index\.md$' || true)

    if [[ -z "$STAGED_MD_FILES" ]]; then
        return 0
    fi

    echo -e "${YELLOW}[1/3] Checking reviewer tags...${NC}"

    local ERRORS=0
    for file in $STAGED_MD_FILES; do
        if [[ ! -f "$file" ]]; then
            continue
        fi

        local FRONT_MATTER=$(sed -n '/^---$/,/^---$/p' "$file" | head -n -1 | tail -n +2)
        local REVIEWED_BY=$(echo "$FRONT_MATTER" | grep -E '^reviewedBy:' | sed 's/reviewedBy:\s*//' | tr -d '"' | tr -d "'" | xargs || true)
        local REVIEWED_DATE=$(echo "$FRONT_MATTER" | grep -E '^reviewedDate:' | sed 's/reviewedDate:\s*//' | tr -d '"' | tr -d "'" | xargs || true)

        local FILE_OK=true
        if [[ -z "$REVIEWED_BY" || "$REVIEWED_BY" != "$GIT_USER" ]]; then
            FILE_OK=false
        fi
        if [[ -z "$REVIEWED_DATE" || "$REVIEWED_DATE" != "$TODAY" ]]; then
            FILE_OK=false
        fi

        if [[ "$FILE_OK" == "true" ]]; then
            echo -e "  ${GREEN}✓${NC} $file"
        else
            echo -e "  ${RED}✗${NC} $file (reviewer: $REVIEWED_BY/$REVIEWED_DATE, expected: $GIT_USER/$TODAY)"
            ERRORS=$((ERRORS + 1))
        fi
    done

    if [[ $ERRORS -gt 0 ]]; then
        echo -e "  ${RED}$ERRORS file(s) need reviewer update. Use <leader>pr in Neovim.${NC}"
        return 1
    fi

    echo -e "  ${GREEN}All files have valid reviewer tags.${NC}"
    return 0
}

#
# Check 2: Markdown linting
#
run_markdown_check() {
    local STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.md$' || true)

    if [[ -z "$STAGED_MD_FILES" ]]; then
        return 0
    fi

    echo -e "${YELLOW}[2/3] Checking markdown formatting...${NC}"

    if ! command -v markdownlint &> /dev/null; then
        echo -e "  ${YELLOW}markdownlint not found, skipping${NC}"
        return 0
    fi

    local ERRORS=0

    for file in $STAGED_MD_FILES; do
        if [[ -f "$file" ]]; then
            # Autofix
            markdownlint --fix "$file" 2>/dev/null || true
            git add "$file"

            # Check remaining errors
            if ! markdownlint "$file" &>/dev/null; then
                echo -e "  ${RED}✗${NC} $file"
                ERRORS=$((ERRORS + 1))
            else
                echo -e "  ${GREEN}✓${NC} $file"
            fi
        fi
    done

    if [[ $ERRORS -gt 0 ]]; then
        echo -e "  ${RED}$ERRORS file(s) have markdown errors.${NC}"
        return 1
    fi

    echo -e "  ${GREEN}All markdown files pass linting.${NC}"
    return 0
}

#
# Check 3: Spell checking
#
run_spelling_check() {
    local STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^content/.*\.md$' || true)

    if [[ -z "$STAGED_MD_FILES" ]]; then
        return 0
    fi

    echo -e "${YELLOW}[3/3] Checking spelling (British English)...${NC}"

    if ! command -v cspell &> /dev/null; then
        echo -e "  ${YELLOW}cspell not found, skipping${NC}"
        return 0
    fi

    local ERRORS=0
    local ALL_UNKNOWN=""

    for file in $STAGED_MD_FILES; do
        if [[ -f "$file" ]]; then
            local OUTPUT=$(cspell --no-progress --no-summary "$file" 2>&1 || true)
            if [[ -n "$OUTPUT" ]]; then
                echo -e "  ${RED}✗${NC} $file"
                local WORDS=$(echo "$OUTPUT" | grep -oP "Unknown word \(\K[^)]+(?=\))" | sort -u | tr '\n' ' ' || true)
                if [[ -n "$WORDS" ]]; then
                    echo -e "      Unknown: $WORDS"
                    ALL_UNKNOWN="${ALL_UNKNOWN} ${WORDS}"
                fi
                ERRORS=$((ERRORS + 1))
            else
                echo -e "  ${GREEN}✓${NC} $file"
            fi
        fi
    done

    if [[ $ERRORS -gt 0 ]]; then
        echo -e "  ${RED}$ERRORS file(s) have spelling errors.${NC}"
        if [[ -n "$ALL_UNKNOWN" ]]; then
            echo -e "  Add valid words to .cspell/project-words.txt"
        fi
        return 1
    fi

    echo -e "  ${GREEN}All content files pass spell check.${NC}"
    return 0
}

#
# Run all checks
#
if ! run_reviewer_check; then
    FAILED=$((FAILED + 1))
fi
echo ""

if ! run_markdown_check; then
    FAILED=$((FAILED + 1))
fi
echo ""

if ! run_spelling_check; then
    FAILED=$((FAILED + 1))
fi
echo ""

#
# Final result
#
if [[ $FAILED -gt 0 ]]; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}COMMIT REJECTED: $FAILED check(s) failed${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "Fix the issues above and try again."
    echo "To bypass (not recommended): git commit --no-verify"
    exit 1
fi

echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}All pre-commit checks passed!${NC}"
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
exit 0
