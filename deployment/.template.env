# Environment Configuration for Kartoza Website Docker Setup
# Copy this file to .env and fill in the values if needed

# Base URL for Hugo site (used for absolute URLs)
BASE_URL=http://localhost:8888

# Port to expose on host machine
PORT=8888

# ERPNext Instance URL (without trailing slash)
GATEWAY_ERPNEXT_API_URL=https://api.do.kartoza.com/erpnext/kartoza-website/api/resource/Lead

# API Key and Secret for ERPNext authentication
# Generate these in ERPNext: User Menu > API Access > Generate Keys
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=