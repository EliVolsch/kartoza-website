# ERPNext API Configuration
# Copy this file to .env and fill in your actual credentials
# The .env file is gitignored for security

# ERPNext Instance URL (without trailing slash)
ERPNEXT_API_URL=https://erp.kartoza.com

# API Key and Secret for ERPNext authentication
# Generate these in ERPNext: User Menu > API Access > Generate Keys
ERPNEXT_API_KEY=your_api_key_here
ERPNEXT_API_SECRET=your_api_secret_here

# Optional: Hugo environment
# HUGO_ENV=production
