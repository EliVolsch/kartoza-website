{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en-GB",
  "languageId": "markdown",
  "dictionaries": [
    "en-gb",
    "softwareTerms",
    "companies",
    "misc"
  ],
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": ".cspell/project-words.txt",
      "addWords": true
    }
  ],
  "ignorePaths": [
    "node_modules",
    ".git",
    "public",
    "resources",
    "themes",
    "static/js",
    "static/css",
    "*.min.js",
    "*.min.css",
    "package-lock.json",
    "flake.lock"
  ],
  "ignoreRegExpList": [
    "{{.*?}}",
    "\\{\\{<.*?>\\}\\}",
    "\\{\\{%.*?%\\}\\}",
    "href=\"[^\"]*\"",
    "src=\"[^\"]*\"",
    "\\[[^\\]]*\\]\\([^)]*\\)",
    "```[\\s\\S]*?```",
    "`[^`]*`",
    "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b",
    "https?://[^\\s\"'>)]*",
    "/img/[^\\s\"'>)]*",
    "\\b[0-9a-f]{7,40}\\b"
  ],
