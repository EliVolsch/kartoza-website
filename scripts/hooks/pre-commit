#!/usr/bin/env bash
#
# Pre-commit hook to verify content pages have current reviewer and date.
#
# Rules:
# 1. Modified markdown files in content/ must have reviewedBy and reviewedDate
# 2. The reviewedBy must match the current git user
# 3. The reviewedDate must be today's date
#
# Skip this check with: git commit --no-verify (not recommended)
#
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or run: ./scripts/install-hooks.sh

set -euo pipefail

# Get current git user and today's date
GIT_USER=$(git config user.name)
TODAY=$(date +%Y-%m-%d)

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track errors
ERRORS=()

# Get list of staged markdown files in content/
STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^content/.*\.md$' || true)

# Skip _index.md files as they are section pages
STAGED_MD_FILES=$(echo "$STAGED_MD_FILES" | grep -v '_index\.md$' || true)

if [[ -z "$STAGED_MD_FILES" ]]; then
    # No content markdown files staged, nothing to check
    exit 0
fi

echo -e "${YELLOW}Checking reviewer tags on modified content pages...${NC}"
echo ""

for file in $STAGED_MD_FILES; do
    if [[ ! -f "$file" ]]; then
        continue
    fi

    # Extract front matter (between first two ---)
    FRONT_MATTER=$(sed -n '/^---$/,/^---$/p' "$file" | head -n -1 | tail -n +2)

    # Check for reviewedBy
    REVIEWED_BY=$(echo "$FRONT_MATTER" | grep -E '^reviewedBy:' | sed 's/reviewedBy:\s*//' | tr -d '"' | tr -d "'" | xargs || true)

    # Check for reviewedDate
    REVIEWED_DATE=$(echo "$FRONT_MATTER" | grep -E '^reviewedDate:' | sed 's/reviewedDate:\s*//' | tr -d '"' | tr -d "'" | xargs || true)

    # Validate
    FILE_OK=true
    FILE_ERRORS=""

    if [[ -z "$REVIEWED_BY" ]]; then
        FILE_OK=false
        FILE_ERRORS="missing reviewedBy"
    elif [[ "$REVIEWED_BY" != "$GIT_USER" ]]; then
        FILE_OK=false
        FILE_ERRORS="reviewedBy is '$REVIEWED_BY', expected '$GIT_USER'"
    fi

    if [[ -z "$REVIEWED_DATE" ]]; then
        FILE_OK=false
        if [[ -n "$FILE_ERRORS" ]]; then
            FILE_ERRORS="$FILE_ERRORS, missing reviewedDate"
        else
            FILE_ERRORS="missing reviewedDate"
        fi
    elif [[ "$REVIEWED_DATE" != "$TODAY" ]]; then
        FILE_OK=false
        if [[ -n "$FILE_ERRORS" ]]; then
            FILE_ERRORS="$FILE_ERRORS, reviewedDate is '$REVIEWED_DATE', expected '$TODAY'"
        else
            FILE_ERRORS="reviewedDate is '$REVIEWED_DATE', expected '$TODAY'"
        fi
    fi

    if [[ "$FILE_OK" == "true" ]]; then
        echo -e "  ${GREEN}✓${NC} $file"
    else
        echo -e "  ${RED}✗${NC} $file"
        echo -e "    ${RED}Error: $FILE_ERRORS${NC}"
        ERRORS+=("$file: $FILE_ERRORS")
    fi
done

echo ""

if [[ ${#ERRORS[@]} -gt 0 ]]; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}COMMIT REJECTED: ${#ERRORS[@]} file(s) need reviewer update${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "Please update the reviewedBy and reviewedDate in each file."
    echo ""
    echo "In Neovim with which-key, use: <leader>pr (Update reviewer)"
    echo "Or manually add to front matter:"
    echo ""
    echo "  reviewedBy: \"$GIT_USER\""
    echo "  reviewedDate: $TODAY"
    echo ""
    echo "To bypass this check (not recommended): git commit --no-verify"
    echo ""
    exit 1
fi

echo -e "${GREEN}All content pages have valid reviewer tags.${NC}"
exit 0
