# API Bridge Configuration
# Copy this file to .env and fill in your values

# Server settings
BRIDGE_PORT=8080
BRIDGE_ENV=development

# =============================================================================
# Authentication Mode
# =============================================================================
# Choose one: "apikey" (default) or "oauth2"
AUTH_MODE=apikey

# =============================================================================
# Option 1: API Key/Secret Authentication (simpler, recommended for testing)
# =============================================================================
# Required when AUTH_MODE=apikey
ERPNEXT_URL=https://your-erpnext-instance.com
ERPNEXT_API_KEY=your-api-key
ERPNEXT_API_SECRET=your-api-secret

# =============================================================================
# Option 2: OAuth2 Bearer Token Authentication (recommended for production)
# =============================================================================
# Required when AUTH_MODE=oauth2
# ERPNEXT_URL=https://your-erpnext-instance.com
# OAUTH2_CLIENT_ID=your-oauth2-client-id
# OAUTH2_CLIENT_SECRET=your-oauth2-client-secret
# OAUTH2_ACCESS_TOKEN=your-oauth2-access-token
# OAUTH2_REFRESH_TOKEN=your-oauth2-refresh-token

# =============================================================================
# CORS and Rate Limiting
# =============================================================================
# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:1313,https://kartoza.com,https://www.kartoza.com

# Rate limiting
RATE_LIMIT=10
RATE_LIMIT_BURST=5

# =============================================================================
# Email notification (optional - for fallback notifications)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@kartoza.com
NOTIFY_EMAIL=info@kartoza.com
